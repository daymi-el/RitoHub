{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Install root deps",
      "type": "npm",
      "script": "install",
      "path": "",
      "problemMatcher": []
    },
    {
      "label": "Install frontend deps",
      "type": "npm",
      "script": "install",
      "path": "frontend",
      "problemMatcher": []
    },
    {
      "label": "Dev: Frontend",
      "type": "npm",
      "script": "dev",
      "path": "frontend",
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "ready in|Local:"
        }
      }
    },
    {
      "label": "Dev: Tauri",
      "type": "npm",
      "script": "dev",
      "path": "",
      "problemMatcher": []
    },
    {
      "label": "Lint: Frontend",
      "type": "npm",
      "script": "lint",
      "path": "frontend",
      "problemMatcher": [
        "$eslint-stylish"
      ]
    },
    {
      "label": "Build: Frontend",
      "type": "npm",
      "script": "build",
      "path": "frontend",
      "problemMatcher": [
        "$tsc"
      ]
    },
    {
      "label": "Build: App",
      "type": "npm",
      "script": "build",
      "path": "",
      "problemMatcher": []
    }
  ]
}
